											Quê quán
										</span>
									</div>
									@* @Html.DropDownList("Tinh", new SelectList(ViewBag.Tinh, "DiaChiId", "Ten"), "Chọn Tỉnh", new { @class = "form-control", id = "tinhDropdown" })
									@Html.DropDownList("Huyen", new SelectList(Enumerable.Empty<SelectListItem>(), "DiaChiId", "Ten"), "Chọn Huyện", new { @class = "form-control", id = "huyenDropdown" })
									@Html.DropDownList("Xa", new SelectList(Enumerable.Empty<SelectListItem>(), "DiaChiId", "Ten"), "Chọn Xã", new { @class = "form-control", id = "xaDropdown" }) *@
								</div>
							</div>
						</div>
						<div class="row">
							<div class="col-md-12 p-1">
								<div class="input-group">
									<div class="input-group-prepend">
										<span class="input-group-text">
											Nơi an nghỉ
										</span>
									</div>
									@Html.DropDownList("nghiatrang", new SelectList(ViewBag.listNghiaTrang, "NghiaTrangId", "Ten"), new { @class = "form-control" })
								</div>
							</div>
						</div>
						<div class="row">
							<div class="col-md-12 p-1">
								<div class="input-group">
									<div class="input-group-prepend">
										<span class="input-group-text">
											SDT liên hệ
										</span>
									</div>
									<input type="text" class="form-control" id="phone" />
								</div>
							</div>
						</div>
						<div class="row">
							<div class="col-md-12 p-1">
								<div class="input-group">
									<div class="input-group-prepend">
										<span class="input-group-text">
											Ngày sinh
										</span>
									</div>
									<input type="datetime-local" class="form-control" id="birthday" />
								</div>
							</div>
						</div>
						<div class="row">
							<div class="col-md-12 p-1">
								<div class="input-group">
									<div class="input-group-prepend">
										<span class="input-group-text">
											Ngày mất
										</span>
									</div>
									<input type="datetime-local" class="form-control" id="deathday" />
								</div>
							</div>
						</div>
						<div class="row">
							<div class="col-md-12 p-1">
								<div class="input-group">
									<div class="input-group-prepend">
										<span class="input-group-text">
											Đơn vị
										</span>
									</div>
									<input type="text" class="form-control" id="unit" />
								</div>
							</div>
						</div>
						<div class="row">
							<div class="col-md-12 p-1">
								<div class="input-group">
									<div class="input-group-prepend">
										<span class="input-group-text">
											Cấp bậc
										</span>
									</div>
									<input type="text" class="form-control" id="rank" />
								</div>
							</div>
						</div>
						<div class="row">
							<div class="col-md-12 p-1">
								<div class="input-group">
									<div class="input-group-prepend">
										<span class="input-group-text">
											Vị trí hàng
										</span>
									</div>
									<input type="number" class="form-control" id="row" min="1" />
								</div>
							</div>
						</div>
						<div class="row">
							<div class="col-md-12 p-1">
								<div class="input-group">
									<div class="input-group-prepend">
										<span class="input-group-text">
											Vị trí cột
										</span>
									</div>
									<input type="number" class="form-control" id="col" min="1" />
								</div>
							</div>
						</div>
						<div class="row">
							<div class="col-md-12 p-1">
								<div class="input-group">
