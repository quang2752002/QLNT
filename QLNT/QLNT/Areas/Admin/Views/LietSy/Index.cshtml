						// Optionally, refresh the list of provinces
						diachi.search(1);
					},
					error: function (err) {
						_layout.showtoast("Error: " + err.responseText);
						$("#loading").hide();
					}
				});
			},
			getLietSy: function (id) {
				$("#phone").val("");
				$("#name").val("");
				$("#birthday").val("");
				$("#deathday").val("");
				$("#thanhpho").val("");
				$("#huyen").val("");
				$("#xa").val("");
				$("#unit").val("");
				$("#rank").val("");
				$("#note").val("");
				
				$.ajax({
					type: 'GET',
					dataType: 'json',
					url: '/Admin/LietSy/getLietSy/' + id,
					success: function (res) {
						// Chuyển đổi chuỗi ngày tháng sang kiểu Date JavaScript
						var birthday = new Date(res.data.ngaySinh);
						var deathday = new Date(res.data.ngayMat);
						var ngaysinh = new Date(res.data.ngaySinh);
						var ngaymat = new Date(res.data.ngayMat);
						// Cộng 1 ngày cho ngày sinh và ngày mất
						birthday.setDate(birthday.getDate() + 1);
						deathday.setDate(deathday.getDate() + 1);

						// Đặt giá trị vào các input type date
						$("#id").val(res.data.lietSyId);
						$("#name").val(res.data.hoTen);
						$("#phone").val(res.data.sdt);

						// So sánh ngày sinh và ngày mất với ngày hiện tại
						if (birthday.toDateString() != new Date().toDateString() && ngaysinh.toDateString() != new Date().toDateString()) {
							$("#birthday").val(birthday.toISOString().split('T')[0]); // Format yyyy-mm-dd
						}
						if (deathday.toDateString() != new Date().toDateString() && ngaymat.toDateString() != new Date().toDateString()) {
							$("#deathday").val(deathday.toISOString().split('T')[0]); // Format yyyy-mm-dd
						}
						if(res.data.diaChiId!=0){
							lietsy.loadTinhUpdate();
						}
						
						$("#unit").val(res.data.donVi);
						$("#rank").val(res.data.capBac);
						$("#row").val(res.data.viTriHang);
						$("#col").val(res.data.viTriCot);
						$("#note").val(res.data.moTa);
						$("#status").val(res.data.tinhTrang);
					}
				});
			},




			delete: function (id) {
				if (confirm("Bạn có chắc chắn muốn xóa không?")) {
					$.ajax({
						type: 'DELETE',
						url: '/Admin/LietSy/Delete/' + id,
						success: function (res) {
							_layout.showtoast(res.mess);
							lietsy.search(1);
						}
					});
				}
			},


		};

		lietsy.init();

		function goto(i) {
			lietsy.search(i);
		}
	</script>
