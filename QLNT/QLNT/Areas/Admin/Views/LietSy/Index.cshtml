@{
	ViewData["Title"] = "Index";
	Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="modal fade" id="new" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
	<div class="modal-dialog modal-lg">
		<div class="modal-content">
			<div class="modal-header">
				<h5 class="modal-title" id="exampleModalLabel"></h5>
				<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
			</div>
			<div class="modal-body">
				<div class="card">
					<div class="card-header">
						<h4>Thêm Mới Liệt Sỹ</h4>
					</div>
					<div class="card-body">
						<div class="row">
							<div class="col-md-12 p-1">
								<div class="input-group">
									<div class="input-group-prepend">
										<span class="input-group-text">
											Họ tên 
										</span>
									</div>
									<input type="text" class="form-control" id="ten" />
								</div>
							</div>
						</div>
						<div class="row">
							<div class="col-md-12 p-1">
								<div class="input-group">
									<div class="input-group-prepend">
										<span class="input-group-text">
											Quê quán
										</span>
									</div>
									@Html.DropDownList("Tinh", new SelectList(ViewBag.Tinh, "DiaChiId", "Ten"), "Chọn Tỉnh", new { @class = "form-control", id = "tinhDropdown" })
									@Html.DropDownList("Huyen", new SelectList(Enumerable.Empty<SelectListItem>(), "DiaChiId", "Ten"), "Chọn Huyện", new { @class = "form-control", id = "huyenDropdown" })
									@Html.DropDownList("Xa", new SelectList(Enumerable.Empty<SelectListItem>(), "DiaChiId", "Ten"), "Chọn Xã", new { @class = "form-control", id = "xaDropdown" })
								</div>
							</div>
						</div>
						<div class="row">
							<div class="col-md-12 p-1">
								<div class="input-group">
									<div class="input-group-prepend">
										<span class="input-group-text">
											Nơi an nghỉ
										</span>
									</div>
									@Html.DropDownList("idnghiatrang", new SelectList(ViewBag.listNghiaTrang, "NghiaTrangId", "Ten"), new { @class = "form-control" })
								</div>
							</div>
						</div>
						<div class="row">
							<div class="col-md-12 p-1">
								<div class="input-group">
									<div class="input-group-prepend">
										<span class="input-group-text">
											SDT liên hệ
										</span>
									</div>
									<input type="text" class="form-control" id="sdt" />
								</div>
							</div>
						</div>
						<div class="row">
							<div class="col-md-12 p-1">
								<div class="input-group">
									<div class="input-group-prepend">
										<span class="input-group-text">
											Ngày sinh
										</span>
									</div>
									<input type="datetime-local" class="form-control" id="ngaysinh" />
								</div>
							</div>
						</div>
						<div class="row">
							<div class="col-md-12 p-1">
								<div class="input-group">
									<div class="input-group-prepend">
										<span class="input-group-text">
											Ngày mất
										</span>
									</div>
									<input type="datetime-local" class="form-control" id="ngaymat" />
								</div>
							</div>
						</div>
						<div class="row">
							<div class="col-md-12 p-1">
								<div class="input-group">
									<div class="input-group-prepend">
										<span class="input-group-text">
											Đơn vị
										</span>
									</div>
									<input type="text" class="form-control" id="donvi" />
								</div>
							</div>
						</div>
						<div class="row">
							<div class="col-md-12 p-1">
								<div class="input-group">
									<div class="input-group-prepend">
										<span class="input-group-text">
											Cấp bậc
										</span>
									</div>
									<input type="text" class="form-control" id="capbac" />
								</div>
							</div>
						</div>
						<div class="row">
							<div class="col-md-12 p-1">
								<div class="input-group">
									<div class="input-group-prepend">
										<span class="input-group-text">
											Vị trí hàng
										</span>
									</div>
									<input type="number" class="form-control" id="vitrihang" min="1" />
								</div>
							</div>
						</div>
						<div class="row">
							<div class="col-md-12 p-1">
								<div class="input-group">
									<div class="input-group-prepend">
										<span class="input-group-text">
											Vị trí cột
										</span>
									</div>
									<input type="number" class="form-control" id="vitricot"  min="1"/>
								</div>
							</div>
						</div>
							<div class="row">
							<div class="col-md-12 p-1">
								<div class="input-group">
									<div class="input-group-prepend">
										<span class="input-group-text">
											Mô tả
										</span>
									</div>
									<textarea type="text" class="form-control" id="mota"></textarea>
								</div>
							</div>
						</div>
						<div class="row">
							<div class="col-md-12 p-1">
								<div class="input-group">
									<div class="input-group-prepend">
										<span class="input-group-text">
											Tình trạng
										</span>
									</div>
									<textarea type="text" class="form-control" id="tinhtrang"></textarea>
								</div>
							</div>
						</div>
						<div class="form-group">
							<div class="col-md-offset-2 col-md-10">
								<button type="button" id="create" class="btn btn-primary" data-bs-dismiss="modal">Thêm mới</button>
								<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Quay lại</button>
							</div>
						</div>
					</div>
				</div>
			</div>
			<div class="modal-footer">
			</div>
		</div>
	</div>
</div>


